# gendoc-template .gitignore
# Prevents build artifacts, generated content, and tooling directories
# from being committed into the template submodule.

# MkDocs build output
site/

# Python virtual environment and cache
.venv/
__pycache__/
*.pyc

# Node.js dependencies
node_modules/

# Cloudflare Wrangler state and cache
.wrangler/

# Temporary Doxygen override files generated by build scripts
*.cf-override.*

# Generated navigation (built from Doxygen index at build time)
**/SUMMARY_EXT.md

# Generated API reference markdown (produced by doxybook2)
**/generated-api/**
